#######################################
# 기본 설정
#######################################
* text=auto eol=lf

#######################################
# 소스 코드 (항상 LF)
#######################################
*.c      text
*.h      text
*.cpp    text
*.hpp    text
*.py     text
*.sh     text
*.dts    text
*.dtsi   text
*.conf   text
*.yaml   text
*.yml    text
*.json   text
*.xml    text
*.md     text

#######################################
# 스크립트 (LF 필수)
#######################################
*.sh     text eol=lf

#######################################
# Windows 전용 스크립트
#######################################
*.bat    text eol=crlf
*.cmd    text eol=crlf

#######################################
# Vivado / Vitis / FPGA 관련
#######################################
*.xdc    text
*.tcl    text
*.v      text
*.sv     text
*.vh     text

#######################################
# Binary (절대 변환 금지)
#######################################
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.pdf    binary

*.bit    binary
*.bin    binary
*.elf    binary
*.xsa    binary
*.xclbin binary

#######################################
# diff 제외 (쓸모없는 비교 방지)
#######################################
*.bit    -diff
*.bin    -diff
*.elf    -diff

#######################################
# merge 전략 (선택)
#######################################
*.lock   merge=ours